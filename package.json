{
  "name": "optimus-ink-seo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port=3009",
    "dev:optimus": "cross-env NEXT_PUBLIC_BRAND=optimus next dev --port=3009",
    "dev:mykiosk": "cross-env NEXT_PUBLIC_BRAND=mykiosk next dev --port=3009",
    "dev:kevo": "cross-env NEXT_PUBLIC_BRAND=kevo next dev --port=3009",
    "dev:optimus:local": "cross-env NEXT_PUBLIC_BRAND=optimus API_BASE_URL=http://localhost:4000 NEXT_PUBLIC_API_URL=http://localhost:4000 next dev --port=3009",
    "dev:mykiosk:local": "cross-env NEXT_PUBLIC_BRAND=mykiosk API_BASE_URL=http://localhost:4000 NEXT_PUBLIC_API_URL=http://localhost:4000 next dev --port=3009",
    "dev:kevo:local": "cross-env NEXT_PUBLIC_BRAND=kevo API_BASE_URL=http://localhost:4000 NEXT_PUBLIC_API_URL=http://localhost:4000 next dev --port=3009",
    "build": "next build",
    "build:optimus": "cross-env NEXT_PUBLIC_BRAND=optimus next build",
    "build:mykiosk": "cross-env NEXT_PUBLIC_BRAND=mykiosk next build",
    "build:kevo": "cross-env NEXT_PUBLIC_BRAND=kevo next build",
    "start": "next start",
    "start:optimus": "cross-env NEXT_PUBLIC_BRAND=optimus next start --port 3009",
    "start:mykiosk": "cross-env NEXT_PUBLIC_BRAND=mykiosk next start --port 3009",
    "start:kevo": "cross-env NEXT_PUBLIC_BRAND=kevo next start --port 3009",
    "lint": "eslint"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
